<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.FlowPane?>

<BorderPane fx:id="category" stylesheets="@../../css/bidder/category-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidnova.controllers.bidder.CategoryController">
    <top>
        <fx:include source="../components/header.fxml" />
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <content>
                <VBox fx:id="content">
                    <Label fx:id="lblCategoryTitle" styleClass="category-title" text="Tên danh mục" />

                    <!-- nơi để product-card -->
                    <FlowPane fx:id="productContainer" />
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
