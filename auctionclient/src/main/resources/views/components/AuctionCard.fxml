<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="350.0" prefWidth="280.0" stylesheets="@../../css/ProductCard.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.daugia.controllers.components.AuctionCardController">
   <children>
      <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@/images/Product.jpg" />
               </image>
            </ImageView>
         </children>
      </VBox>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0" styleClass="product-info-container">
         <children>
            <Label fx:id="titleLabel" styleClass="product-name" text="Tung Tung Tung Sahur" wrapText="true" />
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" styleClass="price-container">
               <children>
                  <Label styleClass="price-label" text="Giá khởi điểm:" />
                  <Label fx:id="priceLabel" styleClass="price-value" text="459,786,375" />
                  <Label styleClass="price-value" text="VNĐ" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" styleClass="status-container">
               <children>
                  <Label styleClass="status-label" text="Trạng thái:" />
                  <Label fx:id="timeLabel" styleClass="status-value" text="Sắp diễn ra" />
               </children>
            </HBox>
            <Button fx:id="actionBtn" mnemonicParsing="false" styleClass="details-button" text="Chi tiết" />
         </children>
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
      </VBox>
   </children>
</VBox>
