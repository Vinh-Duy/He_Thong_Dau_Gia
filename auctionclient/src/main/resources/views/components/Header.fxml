<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane stylesheets="@../../css/components/header-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidnova.controllers.components.HeaderController">
    <HBox fx:id="header" alignment="CENTER" minHeight="80.0" spacing="30.0">
        <Label styleClass="logo" text="BidNova">
         <HBox.margin>
            <Insets />
         </HBox.margin></Label>
        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="650.0" spacing="20.0" styleClass="menu">
            <children>
                <Label onMouseClicked="#showTrangChu" styleClass="text, menu-item-active" text="Trang chủ" />
                
                <MenuButton text="Danh mục đấu giá">
                    <items>
                        <MenuItem onAction="#showDanhMucBatDongSan" text="Bất động sản" />
                        <MenuItem onAction="#showDanhMucTaiSanNhaNuoc" text="Tài sản nhà nước" />
                        <MenuItem onAction="#showDanhMucPhuongTienXeCo" text="Phương tiện - Xe cộ" />
                        <MenuItem onAction="#showDanhMucSuuTamNgheThuat" text="Sưu tầm - nghệ thuật" />
                        <MenuItem onAction="#showDanhMucTaiSanKhac" text="Tài sản khác" />
                    </items>
                </MenuButton>
                
                <MenuButton text="Phòng đấu giá">
                    <items>
                        <MenuItem onAction="#showDanhMucSapDauGia" text="Sắp đấu giá" />
                        <MenuItem onAction="#showDanhMucDangDauGia" text="Đang đấu giá" />
                        <MenuItem onAction="#showDanhMucDaDauGia" text="Đã đấu giá" />
                    </items>
                </MenuButton>

                <Label fx:id="gioiThieuLabel" onMouseClicked="#showGioiThieu" styleClass="text" text="Giới thiệu" />
                
                <Label fx:id="lienHeLabel" onMouseClicked="#showLienHe" styleClass="text" text="Liên hệ" />
            </children>
        </HBox>
        
        <VBox alignment="CENTER_RIGHT" spacing="2">
            <Label fx:id="timeLabel" style="-fx-font-weight: bold;" text="00:00:00" />
            <Label fx:id="dateLabel" text="Ngày tháng năm" />
        </VBox>
        
        <HBox alignment="CENTER" spacing="15.0">
            <Label onMouseClicked="#goToSignup" styleClass="signup-btn" text="Đăng ký" />
            <Label onMouseClicked="#goToSignin" styleClass="signin-btn" text="Đăng nhập" />
         <HBox.margin>
            <Insets />
         </HBox.margin>
        </HBox>
      <StackPane.margin>
         <Insets />
      </StackPane.margin>
    </HBox>
</StackPane>
