<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox spacing="20" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.daugia.controllers.seller.AddProductController"
      style="-fx-background-color: #f4f4f4;">
    
    <padding>
        <Insets top="20" right="40" bottom="30" left="40"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <Label text="🚪 Đăng xuất" onMouseClicked="#goBackHome" 
               style="-fx-text-fill: #e74c3c; -fx-cursor: hand; -fx-font-weight: bold;"/>
    </HBox>

    <Text text="ĐĂNG SẢN PHẨM ĐẤU GIÁ MỚI" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-fill: #2c3e50;"/>

    <GridPane hgap="15" vgap="15" alignment="CENTER">
        <Label text="Tên sản phẩm:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtName" promptText="Ví dụ: iPhone 15 Pro Max" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="400"/>

        <Label text="Mô tả chi tiết:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
        <TextArea fx:id="txtDescription" promptText="Tình trạng máy, phụ kiện kèm theo..." GridPane.columnIndex="1" GridPane.rowIndex="1" prefHeight="100" wrapText="true"/>

        <Label text="Phân loại sản phẩm:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cmbCategory" promptText="-- Chọn loại --" prefWidth="400" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Giá khởi điểm (VNĐ):" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtStartingPrice" promptText="Ví dụ: 1000000" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Ngày kết thúc:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold;"/>
        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="4">
            <DatePicker fx:id="dateEnd" promptText="Chọn ngày" prefWidth="150"/>
            <Label text="Giờ (HH:mm):" style="-fx-alignment: center; -fx-padding: 5 0 0 0;"/>
            <TextField fx:id="txtTimeEnd" promptText="18:00" prefWidth="80"/>
        </HBox>

        <HBox spacing="15" alignment="CENTER_RIGHT" GridPane.columnIndex="1" GridPane.rowIndex="5">
            <Button text="Làm mới" onAction="#handleClear" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;"/>
            <Button text="Đăng Sản Phẩm" onAction="#handleAddProduct" 
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand;"/>
        </HBox>
    </GridPane>
</VBox>