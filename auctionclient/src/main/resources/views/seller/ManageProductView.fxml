<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox spacing="15" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.daugia.controllers.seller.ManageProductController"
      style="-fx-background-color: #f4f4f4; -fx-padding: 20;">
    
    <HBox alignment="CENTER_LEFT">
        <Label text="← Quay lại Trang chủ" onMouseClicked="#goBackHome" 
               style="-fx-text-fill: #3498db; -fx-cursor: hand; -fx-font-weight: bold;"/>
    </HBox>

    <Label text="QUẢN LÝ KHO HÀNG ĐẤU GIÁ" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <TableView fx:id="productTable" VBox.vgrow="ALWAYS" prefHeight="400">
        <columns>
            <TableColumn text="ID" prefWidth="50" style="-fx-alignment: CENTER;">
                <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
            </TableColumn>
            <TableColumn text="Tên sản phẩm" prefWidth="250">
                <cellValueFactory><PropertyValueFactory property="name"/></cellValueFactory>
            </TableColumn>
            <TableColumn text="Giá khởi điểm" prefWidth="150" style="-fx-alignment: CENTER-RIGHT;">
                <cellValueFactory><PropertyValueFactory property="startingPrice"/></cellValueFactory>
            </TableColumn>
            <TableColumn text="Trạng thái" prefWidth="150" style="-fx-alignment: CENTER;">
                <cellValueFactory><PropertyValueFactory property="status"/></cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Đăng mới (+)" onAction="#handleAdd" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Sửa sản phẩm" onAction="#handleEdit" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Xóa sản phẩm" onAction="#handleDelete" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
</VBox>