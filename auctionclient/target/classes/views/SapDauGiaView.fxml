<BorderPane fx:id="mainBorderPane" prefWidth="1200" prefHeight="700" 
            xmlns="http://javafx.com/javafx/25" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.controllers.SapDauGiaController">

    <center>
        <VBox alignment="CENTER" spacing="30" style="-fx-padding: 80 40;">
            <Label text="SDG" 
                   style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #c8102e;"/>
            
            <Label text="Danh sách tài sản bất động sản đang được đấu giá" 
                   style="-fx-font-size: 18px; -fx-text-fill: #555;"/>
            
            <Label text="Nội dung chi tiết sẽ được cập nhật..." 
                   style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
        </VBox>
    </center>
</BorderPane>