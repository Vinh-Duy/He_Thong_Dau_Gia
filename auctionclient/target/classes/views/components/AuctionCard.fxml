<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.daugia.controllers.components.AuctionCardController"
      styleClass="card" spacing="12" alignment="CENTER" 
      prefWidth="220" prefHeight="300">
    
    <ImageView fx:id="imgProduct" fitWidth="180" fitHeight="140" preserveRatio="true"/>
    
    <Label fx:id="lblName" text="Tên sản phẩm" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
    
    <Label fx:id="lblPrice" text="0 VNĐ" style="-fx-text-fill: #d71920; -fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <Label fx:id="lblTime" text="Còn lại: 2 ngày" style="-fx-text-fill: #555;"/>
    
    <Button text="Đấu giá ngay" onAction="#handleBidClick" styleClass="btn-primary" prefWidth="180"/>
</VBox>