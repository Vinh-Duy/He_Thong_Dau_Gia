<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane stylesheets="@../../css/glass-header.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.daugia.controllers.components.HeaderController">
    
    <VBox minHeight="80.0" styleClass="glassy-header-background" />

    <HBox fx:id="header" alignment="CENTER" minHeight="80.0" spacing="30.0" styleClass="header">
      <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../images/Logo.png" />
         </image>
      </ImageView>
        
        <HBox alignment="CENTER" spacing="15.0" HBox.hgrow="ALWAYS">
            <Label fx:id="trangChuLabel" onMouseClicked="#showTrangChu" text="Trang chủ">
            <styleClass>
               <String fx:value="menu-item" />
               <String fx:value="menu-item-active" />
            </styleClass></Label>
            <Label fx:id="taiSanLabel" onMouseClicked="#showTaiSanMenu" styleClass="menu-item" text="Danh mục đấu giá" />
            <Label fx:id="phienDauGiaLabel" onMouseClicked="#showPhienDauGiaMenu" styleClass="menu-item" text="Phòng đấu giá" />
            <Label fx:id="gioiThieuLabel" onMouseClicked="#showGioiThieu" styleClass="menu-item" text="Giới thiệu" />
            <Label fx:id="lienHeLabel" onMouseClicked="#showLienHe" styleClass="menu-item" text="Liên hệ" />
        </HBox>
        
        <VBox alignment="CENTER_RIGHT" spacing="2">
            <Label fx:id="timeLabel" style="-fx-text-fill: white; -fx-font-weight: bold;" text="00:00:00" />
            <Label fx:id="dateLabel" style="-fx-text-fill: white; -fx-font-size: 11px;" text="Ngày tháng năm" />
        </VBox>
        
        <HBox alignment="CENTER" spacing="15.0">
            <Label onMouseClicked="#goToSignupClick" styleClass="btn-galaxy-transparent" text="Đăng ký" />
            <Label onMouseClicked="#goToLoginClick" styleClass="btn-galaxy-filled" text="Đăng nhập" />
        </HBox>
      <padding>
         <Insets left="80.0" right="80.0" />
      </padding>
    </HBox>
</StackPane>
