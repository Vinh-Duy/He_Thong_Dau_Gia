<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="10" stylesheets="@../../css/admin/admin-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidnova.controllers.admin.AdminController">
    <Label styleClass="title" text="QUẢN LÝ NGƯỜI DÙNG" />
    <HBox spacing="10.0">
        <children>
            <Button onAction="#handleRefresh" styleClass="btn, refresh-btn" text="Làm mới danh sách">
                <graphic>
                    <FontAwesomeIconView glyphName="REFRESH" size="16" />
                </graphic>
            </Button>

            <Button onAction="#handleDelete" styleClass="btn, delete-btn" text="Xóa người dùng">
                <graphic>
                    <FontAwesomeIconView glyphName="USER_TIMES" size="16" />
                </graphic>
            </Button>

            <Button onAction="#handleLogout" styleClass="btn, logout-btn" text="Đăng xuất">
                <graphic>
                    <FontAwesomeIconView glyphName="SIGN_OUT" size="16" />
                </graphic>
            </Button>
        </children>
    </HBox>

    <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol" text="ID" />
            <TableColumn fx:id="usernameCol" text="Tên đăng nhập" />
            <TableColumn fx:id="fullNameCol" text="Họ và tên" />
            <TableColumn fx:id="emailCol" text="Email" />
            <TableColumn fx:id="roleCol" text="Quyền" />
        </columns>
    </TableView>
</VBox>
