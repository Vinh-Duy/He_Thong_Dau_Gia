<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../../css/bidder/category-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidnova.controllers.bidder.CategoryController">
    <top>
        <fx:include source="../components/header.fxml" />
    </top>

    <center>
        <ScrollPane fitToWidth="true">
         <content>
            <VBox prefHeight="200.0" prefWidth="100.0" style="-fx-padding: 40;" styleClass="content">
               <children>
                  <HBox prefHeight="100.0" prefWidth="200.0" styleClass="category-item">
                        <children>
                            <Label focusTraversable="false" styleClass="title" text="Danh mục" textFill="WHITE" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblTitle" styleClass="title" text="Bất động sản" />
                        </children>
                  </HBox>

                  <FlowPane fx:id="productContainer" prefHeight="200.0" prefWidth="200.0" />
               </children>
            </VBox>
         </content>
        </ScrollPane>
    </center>
</BorderPane>
