<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1200" stylesheets="@../../css/common/lien-he-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidnova.controllers.common.LienHeController">
    <top>
        <fx:include source="../components/header.fxml" />
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <content>
                <HBox fx:id="content" alignment="CENTER">
                    <children>
                        <HBox styleClass="card" alignment="CENTER_LEFT">
                            <children>
                                <FontAwesomeIconView glyphName="MAP_MARKER" size="35" styleClass="icon" />

                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="title" text="Địa chỉ" />
                                        <Label text="144 Xuân Thủy - Cầu Giấy - Hà Nội" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox styleClass="card" alignment="CENTER_LEFT">
                            <children>
                                <FontAwesomeIconView glyphName="PHONE" size="35" styleClass="icon" />
                                
                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="title" text="Số điện thoại" />
                                        <Label text="0912743JQK" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox styleClass="card" alignment="CENTER_LEFT">
                            <children>
                                <FontAwesomeIconView glyphName="ENVELOPE" size="30" styleClass="icon" />
                                
                                <VBox alignment="CENTER_LEFT">
                                <children>
                                    <Label styleClass="title" text="Email" />
                                    <Label text="vnu@vnu.edu.vn" />
                                </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
