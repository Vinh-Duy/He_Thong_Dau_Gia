<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="auctionCard" alignment="TOP_CENTER" spacing="12" styleClass="card" stylesheets="@../../css/components/auction-card-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidnova.controllers.components.AuctionCardController">
    
    <ImageView fx:id="imgProduct" fitHeight="140" fitWidth="300.0" preserveRatio="true" />
    <VBox prefHeight="200.0" prefWidth="100.0">
        <children>
            
            <Label fx:id="lblName" style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Tên sản phẩm" />
            
            <Label fx:id="lblPrice" style="-fx-text-fill: #d71920; -fx-font-size: 18px; -fx-font-weight: bold;" text="0 VNĐ" />
            
            <Label fx:id="lblTime" style="-fx-text-fill: #555;" text="Còn lại: 2 ngày" />
            
            <Button onAction="#handleBidClick" prefWidth="180" styleClass="btn-primary" text="Đấu giá ngay" />
        </children>
    </VBox>
</VBox>
