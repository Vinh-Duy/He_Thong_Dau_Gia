<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@../../css/components/product-card-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidnova.controllers.components.ProductCardController">
    <children>
        <ImageView fx:id="imgProduct" pickOnBounds="true" preserveRatio="true" />
        <Label fx:id="lblName" styleClass="title" />
        <Label fx:id="lblPrice" styleClass="startingPrice" />
        <Label fx:id="btn" text="Chi tiết">
            <VBox.margin>
                <Insets top="20" right="0" bottom="0" left="20" />
            </VBox.margin>
        </Label>
    </children>
</VBox>
