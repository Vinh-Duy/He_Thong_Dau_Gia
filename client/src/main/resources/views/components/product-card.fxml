<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="card" stylesheets="@../../css/components/product-card-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidnova.controllers.components.ProductCardController">
    <children>
        <Pane fx:id="imgProduct" />
        <VBox fx:id="content">
            <children>
                <Label fx:id="lblName" alignment="TOP_LEFT" styleClass="title" />
                <Label fx:id="lblPrice" styleClass="startingPrice" />
                <Label fx:id="btn" text="Chi tiết" />
            </children>
        </VBox>
    </children>
</VBox>
