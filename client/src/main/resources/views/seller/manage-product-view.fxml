<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="15" stylesheets="@../../css/seller/manage-product-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidnova.controllers.seller.ManageProductController">
    
    <HBox alignment="CENTER_LEFT">
        <Button mnemonicParsing="false" onAction="#goBackHome" styleClass="btn, logout-btn" text="Đăng xuất">
            <graphic>
                <FontAwesomeIconView glyphName="SIGN_OUT" />
            </graphic>
        </Button>
    </HBox>

    <Label styleClass="title" text="QUẢN LÝ KHO HÀNG ĐẤU GIÁ" />

    <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol" text="ID" />
            <TableColumn fx:id="nameCol" text="Tên sản phẩm" />
            <TableColumn fx:id="descriptionCol" text="Mô tả" />
            <TableColumn fx:id="categoryCol" text="Danh mục" />
            <TableColumn fx:id="startPriceCol" text="Giá khởi điểm" />
            <TableColumn fx:id="currentPriceCol" text="Giá hiện tại" />
            <TableColumn fx:id="startTimeCol" text="Ngày bắt đầu" />
            <TableColumn fx:id="endTimeCol" text="Ngày kết thúc" />
            <TableColumn fx:id="statusCol" text="Trạng thái" />
            <TableColumn fx:id="sellerIdCol" text="ID người bán" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button onAction="#handleAdd" styleClass="btn, add-btn" text="Đăng mới">
            <graphic>
                <FontAwesomeIconView glyphName="CART_PLUS" />
            </graphic>
        </Button>
        
        <Button onAction="#handleEdit" styleClass="btn, edit-btn" text="Sửa sản phẩm">
            <graphic>
                <FontAwesomeIconView glyphName="PENCIL_SQUARE_ALT" />
            </graphic>
        </Button>
        
        <Button onAction="#handleDelete" styleClass="btn, delete-btn" text="Xóa sản phẩm">
            <graphic>
                <FontAwesomeIconView glyphName="TRASH_ALT" />
            </graphic>
        </Button>
    </HBox>
</VBox>
