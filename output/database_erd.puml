@startuml Auction_Database_ERD
!define TABLENAME_COLOR #F1F1F1
!define COLUMN_COLOR #F1F1F1
!define RELATION_COLOR #3D5A80

skinparam entity {
  BackgroundColor #F1F1F1
  BorderColor #3D5A80
  BorderThickness 2
  FontColor #000000
}

skinparam linetype ortho
skinparam arrow {
  Color #3D5A80
  Thickness 2
}

entity "👤 USERS" as users {
  * **id** : INT <<PK>>
  --
  * username : VARCHAR(50) <<UNIQUE>>
  * password : VARCHAR(255)
  token : VARCHAR(255)
  role : VARCHAR(50) [ADMIN|BIDDER|SELLER]
  full_name : VARCHAR(100)
  email : VARCHAR(100)
  phone : VARCHAR(20)
  gender : VARCHAR(10)
}

entity "🏆 AUCTIONS" as auctions {
  * **id** : VARCHAR(50) <<PK>>
  --
  * name : VARCHAR(255)
  * start_price : DECIMAL(20,2)
  current_highest_bid : DECIMAL(20,2)
  status : VARCHAR(50) [OPEN|CLOSED|CANCELLED]
  category : VARCHAR(100)
  description : TEXT
  end_time : VARCHAR(50)
  seller_id : INT <<FK>>
  created_at : TIMESTAMP
}

entity "🤖 AUTO_BIDS" as auto_bids {
  * **id** : INT <<PK, AI>>
  --
  * auction_id : VARCHAR(50) <<FK>>
  * username : VARCHAR(100)
  * max_bid : DECIMAL(20,2)
  * increment : DECIMAL(20,2)
  is_active : TINYINT(1) [0|1]
  created_at : BIGINT
}

users ||--o{ auctions : "bán (seller_id)"
auctions ||--o{ auto_bids : "có (auction_id)"

note right of users
  Người dùng hệ thống
  - Admin: quản lý
  - Seller: đăng sản phẩm
  - Bidder: đấu giá
end note

note right of auctions
  Phiên đấu giá sản phẩm
  - Giá bắt đầu (start_price)
  - Giá cao nhất hiện tại
  - 4 danh mục chính
end note

note right of auto_bids
  Tự động đấu giá
  - Đơn vị tăng giá (increment)
  - Giá tối đa (max_bid)
  - FIFO execution
end note

@enduml
